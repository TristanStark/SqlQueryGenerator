<Window x:Class="SqlQueryGenerator.App.DdlExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export du DDL"
        Height="420"
        Width="860"
        MinHeight="360"
        MinWidth="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Générez une requête d'aide pour Oracle ou SQLite, puis exécutez-la dans votre client SQL. La requête générée est aussi copiée dans le presse-papier."
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"
                   Foreground="#334155" />

        <WrapPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Moteur source"
                       VerticalAlignment="Center"
                       Margin="0,4,8,4"
                       FontWeight="SemiBold" />
            <ComboBox Width="150"
                      ItemsSource="{Binding DdlExportDialects}"
                      SelectedItem="{Binding DdlExportDialect, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      Margin="0,0,12,0" />
            <TextBlock Text="Schéma / base"
                       VerticalAlignment="Center"
                       Margin="0,4,8,4"
                       FontWeight="SemiBold" />
            <TextBox Width="220"
                     Text="{Binding DdlSchemaName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Oracle : propriétaire du schéma. SQLite : base attachée, généralement main." />
            <Button Content="Générer la requête d'export DDL"
                    Command="{Binding GenerateDdlExportCommand}"
                    Margin="12,0,0,0"
                    ToolTip="Construit la requête d'aide et la copie dans le presse-papier." />
        </WrapPanel>

        <TextBox Grid.Row="2"
                 Text="{Binding DdlExportSql, Mode=OneWay}"
                 FontFamily="Consolas"
                 FontSize="13"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap" />

        <DockPanel Grid.Row="3" Margin="0,12,0,0" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left"
                       Text="Oracle utilise DBMS_METADATA. SQLite utilise sqlite_master."
                       VerticalAlignment="Center"
                       Foreground="#475569" />
            <Button DockPanel.Dock="Right"
                    Content="Fermer"
                    Width="92"
                    Click="Close_Click" />
        </DockPanel>
    </Grid>
</Window>
