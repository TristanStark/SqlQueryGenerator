<Window x:Class="SqlQueryGenerator.App.DdlExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export du DDL"
        Height="620"
        Width="980"
        MinHeight="520"
        MinWidth="860"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Générez une requête d'aide pour Oracle ou SQLite, puis exécutez-la dans votre client SQL. Vous pouvez aussi générer une instruction CREATE MATERIALIZED VIEW depuis la requête courante."
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"
                   Foreground="#334155" />

        <WrapPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Moteur source"
                       VerticalAlignment="Center"
                       Margin="0,4,8,4"
                       FontWeight="SemiBold" />
            <ComboBox Width="150"
                      ItemsSource="{Binding DdlExportDialects}"
                      SelectedItem="{Binding DdlExportDialect, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      Margin="0,0,12,0" />
            <TextBlock Text="Schéma / base"
                       VerticalAlignment="Center"
                       Margin="0,4,8,4"
                       FontWeight="SemiBold" />
            <TextBox Width="220"
                     Text="{Binding DdlSchemaName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Oracle : propriétaire du schéma. SQLite : base attachée, généralement main." />
            <Button Content="Générer la requête d'export DDL"
                    Command="{Binding GenerateDdlExportCommand}"
                    Margin="12,0,0,0"
                    ToolTip="Construit la requête d'aide et la copie dans le presse-papier." />
        </WrapPanel>

        <TextBox Grid.Row="2"
                 Text="{Binding DdlExportSql, Mode=OneWay}"
                 FontFamily="Consolas"
                 FontSize="13"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap" />

        <Separator Grid.Row="3" Margin="0,14,0,14" />

        <WrapPanel Grid.Row="4" Margin="0,0,0,12">
            <TextBlock Text="Nom de la vue matérialisée"
                       VerticalAlignment="Center"
                       Margin="0,4,8,4"
                       FontWeight="SemiBold" />
            <TextBox Width="280"
                     Text="{Binding MaterializedViewName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Nom SQL de la vue matérialisée à créer, éventuellement schema.nom_vue." />
            <Button Content="Créer DDL depuis la requête courante"
                    Command="{Binding GenerateCreateMaterializedViewCommand}"
                    Margin="12,0,0,0"
                    ToolTip="Génère CREATE MATERIALIZED VIEW ... AS SELECT ... et copie le résultat dans le presse-papier." />
        </WrapPanel>

        <TextBox Grid.Row="5"
                 Text="{Binding CreateMaterializedViewSql, Mode=OneWay}"
                 FontFamily="Consolas"
                 FontSize="13"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap" />

        <DockPanel Grid.Row="6" Margin="0,12,0,0" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left"
                       Text="Oracle utilise DBMS_METADATA. SQLite ne supporte pas les vues matérialisées natives."
                       VerticalAlignment="Center"
                       Foreground="#475569" />
            <Button DockPanel.Dock="Right"
                    Content="Fermer"
                    Width="92"
                    Click="Close_Click" />
        </DockPanel>
    </Grid>
</Window>
