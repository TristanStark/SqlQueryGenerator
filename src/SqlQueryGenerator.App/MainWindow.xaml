<Window x:Class="SqlQueryGenerator.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SqlQueryGenerator.App.ViewModels"
        mc:Ignorable="d"
        Title="SQL Query Generator"
        Height="1040"
        Width="1920"
        MinHeight="820"
        MinWidth="1500"
        WindowState="Maximized">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <Style TargetType="{x:Type Button}">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="MinWidth" Value="86" />
        </Style>
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="MinHeight" Value="30" />
        </Style>
        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="MinHeight" Value="30" />
        </Style>
        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Margin" Value="8,4,4,4" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="RowHeight" Value="34" />
            <Setter Property="ColumnHeaderHeight" Value="34" />
            <Setter Property="EnableRowVirtualization" Value="True" />
            <Setter Property="EnableColumnVirtualization" Value="True" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        </Style>
        <Style TargetType="{x:Type GroupBox}">
            <Setter Property="Margin" Value="6" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="PanelTitle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="19" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="4,0,4,8" />
        </Style>
        <Style x:Key="HelpText" TargetType="{x:Type TextBlock}">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#4B5563" />
            <Setter Property="Margin" Value="4,0,4,8" />
        </Style>
        <Style x:Key="SectionHint" TargetType="{x:Type TextBlock}">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="Margin" Value="8,4,8,6" />
            <Setter Property="FontWeight" Value="Normal" />
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <DockPanel LastChildFill="True" Background="#F8FAFC">
        <Border DockPanel.Dock="Top" Background="#111827" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.Column="0" VerticalAlignment="Center">
                    <Button Content="Charger schéma SQL/TXT" Click="OpenSchema_Click" ToolTip="Charge un fichier .sql ou .txt contenant des CREATE TABLE et/ou COMMENT ON COLUMN." />
                    <Button Content="Importer doc CSV/TSV" Click="OpenDocumentation_Click" ToolTip="Importe une documentation table/colonne depuis un fichier CSV, TSV ou TXT exporté d'un tableau." />
                    <Button Content="Coller schéma" Click="PasteSchema_Click" ToolTip="Colle un schéma depuis le presse-papier." />
                    <Button Content="Copier SQL" Click="CopySql_Click" ToolTip="Copie la requête générée dans le presse-papier." />
                    <Button Content="Vider requête" Command="{Binding ClearQueryCommand}" />
                </WrapPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding Status}"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="18,0"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />

                <Border Grid.Column="2" Background="#1F2937" CornerRadius="6" Padding="10,6" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SchemaSummary}" Foreground="#E5E7EB" FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="2.2*" MinHeight="500" />
                <RowDefinition Height="8" />
                <RowDefinition Height="*" MinHeight="220" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="480" MinWidth="390" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" MinWidth="900" />
                </Grid.ColumnDefinitions>

                <GroupBox Grid.Column="0" Header="1. Colonnes disponibles">
                    <DockPanel LastChildFill="True">
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Filtre, sélectionne, puis utilise les boutons rapides ou glisse une colonne vers un onglet de construction."
                                   Style="{StaticResource SectionHint}" />

                        <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding ColumnSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Recherche dans table, colonne, type ou commentaire." />
                            <Button Grid.Column="1" Content="Effacer" Command="{Binding ClearColumnSearchCommand}" />
                        </Grid>

                        <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                            <Button Content="+ Sélection" Command="{Binding AddSelectedColumnCommand}" ToolTip="Ajoute la colonne au SELECT." />
                            <Button Content="+ Filtre" Command="{Binding AddSelectedFilterCommand}" ToolTip="Ajoute la colonne au WHERE." />
                            <Button Content="+ Groupe" Command="{Binding AddSelectedGroupByCommand}" ToolTip="Ajoute la colonne au GROUP BY." />
                            <Button Content="+ Tri" Command="{Binding AddSelectedOrderByCommand}" ToolTip="Ajoute la colonne au ORDER BY." />
                            <Button Content="+ Agrégat" Command="{Binding AddSelectedAggregateCommand}" ToolTip="Ajoute un COUNT/SUM/AVG/etc." />
                        </WrapPanel>

                        <Border Margin="4" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4">
                            <TreeView x:Name="AvailableColumnsTree"
                                      ItemsSource="{Binding Tables}"
                                      SelectedItemChanged="AvailableColumnsTree_SelectedItemChanged"
                                      PreviewMouseMove="ColumnsTree_PreviewMouseMove"
                                      MouseDoubleClick="ColumnsTree_MouseDoubleClick"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                    </Style>
                                </TreeView.ItemContainerStyle>
                                <TreeView.Resources>
                                    <HierarchicalDataTemplate DataType="{x:Type vm:TableItemViewModel}" ItemsSource="{Binding Columns}">
                                        <StackPanel Orientation="Horizontal" ToolTip="{Binding Comment}">
                                            <TextBlock Text="🗂 " Margin="0,0,4,0" />
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                            <TextBlock Text=" (" Foreground="#64748B" />
                                            <TextBlock Text="{Binding ColumnCount}" Foreground="#64748B" />
                                            <TextBlock Text=")" Foreground="#64748B" />
                                        </StackPanel>
                                    </HierarchicalDataTemplate>

                                    <DataTemplate DataType="{x:Type vm:ColumnItemViewModel}">
                                        <Grid Margin="0,2,0,2" ToolTip="{Binding DisplayName}">
                                            <Grid.ContextMenu>
                                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                    <MenuItem Header="Ajouter au SELECT" Click="AddColumnToSelectMenu_Click" />
                                                    <MenuItem Header="Ajouter au filtre WHERE" Click="AddColumnToFilterMenu_Click" />
                                                    <MenuItem Header="Ajouter au GROUP BY" Click="AddColumnToGroupMenu_Click" />
                                                    <MenuItem Header="Ajouter au tri ORDER BY" Click="AddColumnToOrderMenu_Click" />
                                                    <Separator />
                                                    <MenuItem Header="Ajouter comme agrégat" Click="AddColumnToAggregateMenu_Click" />
                                                </ContextMenu>
                                            </Grid.ContextMenu>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="26" />
                                                <ColumnDefinition Width="26" />
                                                <ColumnDefinition Width="30" />
                                                <ColumnDefinition Width="190" />
                                                <ColumnDefinition Width="105" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Visibility="{Binding IsPrimaryKey, Converter={StaticResource BoolToVisibility}}" Background="#FEF3C7" BorderBrush="#F59E0B" BorderThickness="1" CornerRadius="3" Padding="2,0" Margin="0,0,4,0" ToolTip="Clé primaire">
                                                <TextBlock Text="PK" Foreground="#92400E" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" />
                                            </Border>
                                            <Border Grid.Column="1" Visibility="{Binding IsForeignKey, Converter={StaticResource BoolToVisibility}}" Background="#E0F2FE" BorderBrush="#0284C7" BorderThickness="1" CornerRadius="3" Padding="2,0" Margin="0,0,4,0" ToolTip="{Binding ForeignKeySummary}">
                                                <TextBlock Text="FK" Foreground="#075985" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" />
                                            </Border>
                                            <Border Grid.Column="2" Visibility="{Binding IsIndexed, Converter={StaticResource BoolToVisibility}}" Background="#DCFCE7" BorderBrush="#16A34A" BorderThickness="1" CornerRadius="3" Padding="2,0" Margin="0,0,4,0" ToolTip="{Binding IndexSummary}">
                                                <TextBlock Text="{Binding IndexBadge}" Foreground="#166534" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" />
                                            </Border>
                                            <TextBlock Grid.Column="3" Text="{Binding Column}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <Border Grid.Column="4" Background="{Binding TypeBackground}" CornerRadius="4" Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding TypeCategory}" Foreground="{Binding TypeForeground}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                            </Border>
                                            <TextBlock Grid.Column="5" Text="{Binding Comment}" Foreground="#475569" Margin="8,0,0,0" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </TreeView.Resources>
                            </TreeView>
                        </Border>
                    </DockPanel>
                </GroupBox>

                <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="#CBD5E1" />

                <GroupBox Grid.Column="2" Header="2. Construire la requête">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Background="#FFFFFF" Padding="8" Margin="4,2,4,8">
                            <WrapPanel VerticalAlignment="Center">
                                <TextBlock Text="Table de départ" VerticalAlignment="Center" Margin="4" FontWeight="SemiBold" />
                                <ComboBox Width="260" ItemsSource="{Binding TableNames}" SelectedItem="{Binding BaseTable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Text="Dialecte" VerticalAlignment="Center" Margin="16,4,4,4" FontWeight="SemiBold" />
                                <ComboBox Width="135" ItemsSource="{Binding Dialects}" SelectedItem="{Binding Dialect, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <CheckBox Content="DISTINCT" IsChecked="{Binding Distinct, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Ajoute SELECT DISTINCT." />
                                <CheckBox Content="Quoter noms" IsChecked="{Binding QuoteIdentifiers, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Protège les noms avec les quotes du dialecte." />
                                <CheckBox Content="Auto GROUP BY" IsChecked="{Binding AutoGroupSelectedColumns, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Ajoute automatiquement les colonnes sélectionnées au GROUP BY quand un agrégat est utilisé." />

                                <TextBlock Text="Limite" VerticalAlignment="Center" Margin="16,4,4,4" FontWeight="SemiBold" />
                                <TextBox Width="90" Text="{Binding LimitRows, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" ToolTip="Nombre maximal de lignes. Vide = aucune limite." />
                                <Button Content="Générer" Command="{Binding GenerateCommand}" />
                            </WrapPanel>
                        </Border>

                        <TabControl Grid.Row="1" Margin="4">
                            <TabItem Header="Sélection">
                                <DockPanel AllowDrop="True" Drop="Select_Drop" DragOver="Drop_DragOver" LastChildFill="True">
                                    <TextBlock DockPanel.Dock="Top" Text="Dépose ici les colonnes à afficher. L'alias est le nom lisible qui apparaîtra dans le résultat." Style="{StaticResource SectionHint}" />
                                    <DataGrid ItemsSource="{Binding SelectedColumns}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Table" Binding="{Binding Table, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="2*" MinWidth="220" />
                                            <DataGridTextColumn Header="Colonne" Binding="{Binding Column, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="2*" MinWidth="220" />
                                            <DataGridTextColumn Header="Alias optionnel" Binding="{Binding Alias, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="2*" MinWidth="240" />
                                            <DataGridTemplateColumn Header="Action" Width="290" MinWidth="270">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="Retirer" HorizontalAlignment="Stretch" MinWidth="145" Padding="12,4" Command="{Binding DataContext.RemoveSelectedColumnCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </TabItem>

                            <TabItem Header="Filtres">
                                <DockPanel AllowDrop="True" Drop="Filter_Drop" DragOver="Drop_DragOver" LastChildFill="True">
                                    <TextBlock DockPanel.Dock="Top" Text="WHERE / HAVING : dépose une colonne normale, ou ajoute un agrégat / une colonne calculée depuis leurs onglets. Les filtres sur agrégats deviennent automatiquement HAVING." Style="{StaticResource SectionHint}" />
                                    <DataGrid ItemsSource="{Binding Filters}">
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="Lien" Width="100" MinWidth="95">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ComboBox ItemsSource="{Binding DataContext.LogicalConnectors, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding Connector, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Type" Binding="{Binding FieldKind, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="0.9*" MinWidth="130" />
                                            <DataGridTextColumn Header="Table / source" Binding="{Binding Table, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1.3*" MinWidth="170" />
                                            <DataGridTextColumn Header="Colonne / alias" Binding="{Binding Column, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1.6*" MinWidth="210" />
                                            <DataGridTemplateColumn Header="Opérateur" Width="155" MinWidth="145">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ComboBox ItemsSource="{Binding DataContext.Operators, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding Operator, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Type valeur" Width="150" MinWidth="140">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ComboBox ItemsSource="{Binding DataContext.FilterValueKinds, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding ValueKind, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Valeur / paramètre" Binding="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="2*" MinWidth="230" />
                                            <DataGridTextColumn Header="Valeur 2" Binding="{Binding SecondValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1.4*" MinWidth="190" />
                                            <DataGridTextColumn Header="Sous-requête" Binding="{Binding SubqueryName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1.5*" MinWidth="190" />
                                            <DataGridTemplateColumn Header="Action" Width="190" MinWidth="170">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="Retirer" HorizontalAlignment="Stretch" MinWidth="145" Padding="12,4" Command="{Binding DataContext.RemoveFilterCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </TabItem>

                            <TabItem Header="Jointures">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="1.15*" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <DockPanel Grid.Row="0" LastChildFill="True">
                                        <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                                            <TextBlock Text="Relations probables détectées" VerticalAlignment="Center" FontWeight="Bold" Margin="8,4" />
                                            <Button Content="Ajouter comme jointure" Command="{Binding AddJoinFromRelationshipCommand}" />
                                            <Button Content="+ Jointure manuelle" Command="{Binding AddManualJoinCommand}" ToolTip="Ajoute une ligne vide modifiable dans les jointures forcées." />
                                        </WrapPanel>
                                        <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4" Margin="4">
                                            <TreeView x:Name="RelationshipsTree"
                                                      ItemsSource="{Binding RelationshipGroups}"
                                                      SelectedItemChanged="RelationshipsTree_SelectedItemChanged"
                                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                                <TreeView.ItemContainerStyle>
                                                    <Style TargetType="TreeViewItem">
                                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                                    </Style>
                                                </TreeView.ItemContainerStyle>
                                                <TreeView.Resources>
                                                    <HierarchicalDataTemplate DataType="{x:Type vm:RelationshipGroupViewModel}" ItemsSource="{Binding Relationships}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="🔗 " Margin="0,0,4,0" />
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                        </StackPanel>
                                                    </HierarchicalDataTemplate>
                                                    <DataTemplate DataType="{x:Type vm:RelationshipItemViewModel}">
                                                        <Grid Margin="0,2,0,2" ToolTip="{Binding Reason}">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="78" />
                                                                <ColumnDefinition Width="280" />
                                                                <ColumnDefinition Width="30" />
                                                                <ColumnDefinition Width="280" />
                                                                <ColumnDefinition Width="80" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <CheckBox Grid.Column="0" Content="Auto" IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Décoche pour empêcher cette relation auto-détectée d'être utilisée par le planificateur automatique." />
                                                            <TextBlock Grid.Column="1" Text="{Binding FromDisplay}" FontWeight="SemiBold" />
                                                            <TextBlock Grid.Column="2" Text="→" HorizontalAlignment="Center" Foreground="#64748B" />
                                                            <TextBlock Grid.Column="3" Text="{Binding ToDisplay}" FontWeight="SemiBold" />
                                                            <TextBlock Grid.Column="4" Text="{Binding Confidence, StringFormat=P0}" Foreground="#166534" FontWeight="SemiBold" />
                                                            <TextBlock Grid.Column="5" Text="{Binding Reason}" Foreground="#475569" TextTrimming="CharacterEllipsis" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </TreeView.Resources>
                                            </TreeView>
                                        </Border>
                                    </DockPanel>
                                    <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" Background="#CBD5E1" />
                                    <DockPanel Grid.Row="2" LastChildFill="True">
                                        <TextBlock DockPanel.Dock="Top" Text="Jointures forcées / manuelles : sélectionne les tables dans les listes, ou glisse une colonne depuis l'arbre vers Colonne gauche / droite. Le drop remplit aussi la table automatiquement." Style="{StaticResource SectionHint}" />
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding Joins}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Background="#FFFFFF" Padding="8" Margin="6,4">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="150" />
                                                                    <ColumnDefinition Width="230" />
                                                                    <ColumnDefinition Width="210" />
                                                                    <ColumnDefinition Width="36" />
                                                                    <ColumnDefinition Width="230" />
                                                                    <ColumnDefinition Width="210" />
                                                                    <ColumnDefinition Width="150" />
                                                                </Grid.ColumnDefinitions>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>

                                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Type" FontWeight="SemiBold" Margin="4,0" />
                                                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Table gauche" FontWeight="SemiBold" Margin="4,0" />
                                                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Colonne gauche" FontWeight="SemiBold" Margin="4,0" />
                                                                <TextBlock Grid.Row="0" Grid.Column="4" Text="Table droite" FontWeight="SemiBold" Margin="4,0" />
                                                                <TextBlock Grid.Row="0" Grid.Column="5" Text="Colonne droite" FontWeight="SemiBold" Margin="4,0" />

                                                                <ComboBox Grid.Row="1" Grid.Column="0" ItemsSource="{Binding DataContext.JoinTypes, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding JoinType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                <ComboBox Grid.Row="1" Grid.Column="1" IsEditable="True" ItemsSource="{Binding DataContext.TableNames, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding FromTable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Text="{Binding FromTable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Choisis la table gauche." />
                                                                <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding FromColumn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AllowDrop="True" DragOver="Drop_DragOver" Drop="JoinLeftColumn_Drop" ToolTip="Glisse ici la colonne gauche. La table gauche sera remplie automatiquement." />

                                                                <TextBlock Grid.Row="1" Grid.Column="3" Text="=" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="18" Foreground="#475569" />

                                                                <ComboBox Grid.Row="1" Grid.Column="4" IsEditable="True" ItemsSource="{Binding DataContext.TableNames, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding ToTable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Text="{Binding ToTable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Choisis la table droite." />
                                                                <TextBox Grid.Row="1" Grid.Column="5" Text="{Binding ToColumn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AllowDrop="True" DragOver="Drop_DragOver" Drop="JoinRightColumn_Drop" ToolTip="Glisse ici la colonne droite. La table droite sera remplie automatiquement." />
                                                                <StackPanel Grid.Row="1" Grid.Column="6" Orientation="Vertical">
                                                                    <Button Content="Retirer" HorizontalAlignment="Stretch" MinWidth="145" Padding="12,4" Command="{Binding DataContext.RemoveJoinCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                                    <Button Content="+ Colonne" HorizontalAlignment="Stretch" MinWidth="145" Padding="12,4" Command="{Binding DataContext.AddJoinPairCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" ToolTip="Ajoute une condition supplémentaire à la jointure composite." />
                                                                </StackPanel>

                                                                <ItemsControl Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="5" ItemsSource="{Binding AdditionalPairs}" Margin="4,8,4,0">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Grid Margin="0,2">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="80" />
                                                                                    <ColumnDefinition Width="210" />
                                                                                    <ColumnDefinition Width="36" />
                                                                                    <ColumnDefinition Width="210" />
                                                                                    <ColumnDefinition Width="120" />
                                                                                </Grid.ColumnDefinitions>
                                                                                <CheckBox Grid.Column="0" Content="Actif" IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Active/désactive cette colonne de jointure." />
                                                                                <TextBox Grid.Column="1" Text="{Binding FromColumn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AllowDrop="True" DragOver="Drop_DragOver" Drop="JoinPairLeftColumn_Drop" ToolTip="Glisse ici une colonne supplémentaire côté gauche." />
                                                                                <TextBlock Grid.Column="2" Text="=" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" />
                                                                                <TextBox Grid.Column="3" Text="{Binding ToColumn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AllowDrop="True" DragOver="Drop_DragOver" Drop="JoinPairRightColumn_Drop" ToolTip="Glisse ici une colonne supplémentaire côté droit." />
                                                                                <Button Grid.Column="4" Content="Retirer" MinWidth="105" Command="{Binding DataContext.RemoveJoinPairCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                                            </Grid>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </DockPanel>
                                </Grid>
                            </TabItem>

                            <TabItem Header="Groupes / agrégats">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <DockPanel Grid.Row="0" AllowDrop="True" Drop="Group_Drop" DragOver="Drop_DragOver" LastChildFill="True">
                                        <TextBlock DockPanel.Dock="Top" Text="GROUP BY : dépose les colonnes par lesquelles regrouper." Style="{StaticResource SectionHint}" />
                                        <DataGrid ItemsSource="{Binding GroupBy}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Table" Binding="{Binding Table, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="2*" MinWidth="260" />
                                                <DataGridTextColumn Header="Colonne" Binding="{Binding Column, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="2*" MinWidth="260" />
                                                <DataGridTemplateColumn Header="Action" Width="190" MinWidth="170">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Button Content="Retirer" HorizontalAlignment="Stretch" MinWidth="145" Padding="12,4" Command="{Binding DataContext.RemoveGroupByCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </DockPanel>
                                    <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" Background="#CBD5E1" />
                                    <DockPanel Grid.Row="2" AllowDrop="True" Drop="Aggregate_Drop" DragOver="Drop_DragOver" LastChildFill="True">
                                        <StackPanel DockPanel.Dock="Top">
                                            <TextBlock Text="Agrégats : COUNT, SUM, AVG, MIN, MAX. Dépose une colonne cible puis choisis la fonction." Style="{StaticResource SectionHint}" />
                                            <TextBlock Text="Option conditionnelle : renseigne une colonne de condition pour générer COUNT/SUM/AVG ... uniquement pour les lignes qui respectent la condition, sans sous-requête." Style="{StaticResource SectionHint}" />
                                        </StackPanel>
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                            <ItemsControl ItemsSource="{Binding Aggregates}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Background="#FFFFFF" Padding="10" Margin="6">
                                                            <StackPanel>
                                                                <WrapPanel>
                                                                    <TextBlock Text="Fonction" VerticalAlignment="Center" FontWeight="SemiBold" Margin="4" />
                                                                    <ComboBox Width="130" ItemsSource="{Binding DataContext.AggregateFunctions, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding Function, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                                                    <TextBlock Text="Table cible" VerticalAlignment="Center" FontWeight="SemiBold" Margin="12,4,4,4" />
                                                                    <TextBox Width="190" Text="{Binding Table, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Table de la colonne à compter/sommer/moyenner." />

                                                                    <TextBlock Text="Colonne cible" VerticalAlignment="Center" FontWeight="SemiBold" Margin="12,4,4,4" />
                                                                    <TextBox Width="190" Text="{Binding Column, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Colonne cible. Pour COUNT, elle peut être un identifiant de paiement. Pour SUM/AVG, choisis une colonne numérique." />

                                                                    <CheckBox Content="Distinct" IsChecked="{Binding Distinct, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="COUNT(DISTINCT ...), SUM(DISTINCT ...), etc." />

                                                                    <TextBlock Text="Alias" VerticalAlignment="Center" FontWeight="SemiBold" Margin="12,4,4,4" />
                                                                    <TextBox Width="210" Text="{Binding Alias, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Nom de la colonne générée, ex: nb_paiements_cb, total_paye." />

                                                                    <Button Content="+ Filtre" MinWidth="95" Padding="10,4" Command="{Binding DataContext.AddAggregateFilterCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" ToolTip="Ajoute cet agrégat comme filtre HAVING." />
                                                                    <Button Content="+ Tri" MinWidth="85" Padding="10,4" Command="{Binding DataContext.AddAggregateOrderByCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" ToolTip="Ajoute cet agrégat au ORDER BY." />
                                                                    <Button Content="Retirer" HorizontalAlignment="Stretch" MinWidth="145" Padding="12,4" Command="{Binding DataContext.RemoveAggregateCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                                </WrapPanel>

                                                                <Border BorderBrush="#E5E7EB" BorderThickness="1,0,0,0" Margin="4,8,4,0" Padding="8,6,0,0">
                                                                    <StackPanel>
                                                                        <TextBlock Text="Condition optionnelle de l'agrégat : ex. mode_reglement = CB ou statut = PAYE. Vide = agrégat normal." Foreground="#374151" FontWeight="Normal" Margin="0,0,0,4" />
                                                                        <WrapPanel>
                                                                            <TextBlock Text="Table condition" VerticalAlignment="Center" FontWeight="SemiBold" Margin="4" />
                                                                            <TextBox Width="190" Text="{Binding ConditionTable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                                                            <TextBlock Text="Colonne condition" VerticalAlignment="Center" FontWeight="SemiBold" Margin="12,4,4,4" />
                                                                            <TextBox Width="190" Text="{Binding ConditionColumn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                                                            <TextBlock Text="Opérateur" VerticalAlignment="Center" FontWeight="SemiBold" Margin="12,4,4,4" />
                                                                            <ComboBox Width="145" ItemsSource="{Binding DataContext.Operators, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding ConditionOperator, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                                                            <TextBlock Text="Valeur" VerticalAlignment="Center" FontWeight="SemiBold" Margin="12,4,4,4" />
                                                                            <TextBox Width="190" Text="{Binding ConditionValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Ex: CB, PAYE, 2024-01-01. Les quotes SQL sont ajoutées automatiquement." />

                                                                            <TextBlock Text="Valeur 2" VerticalAlignment="Center" FontWeight="SemiBold" Margin="12,4,4,4" />
                                                                            <TextBox Width="170" Text="{Binding ConditionSecondValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Utilisé pour BETWEEN." />
                                                                        </WrapPanel>
                                                                    </StackPanel>
                                                                </Border>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </DockPanel>
                                </Grid>
                            </TabItem>

                            <TabItem Header="Tri">
                                <DockPanel AllowDrop="True" Drop="Order_Drop" DragOver="Drop_DragOver" LastChildFill="True">
                                    <TextBlock DockPanel.Dock="Top" Text="ORDER BY : dépose une colonne normale, ou ajoute un agrégat / une colonne calculée depuis leurs onglets. Les tris sur alias restent lisibles." Style="{StaticResource SectionHint}" />
                                    <DataGrid ItemsSource="{Binding OrderBy}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Type" Binding="{Binding FieldKind, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="0.9*" MinWidth="130" />
                                            <DataGridTextColumn Header="Table / source" Binding="{Binding Table, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1.5*" MinWidth="210" />
                                            <DataGridTextColumn Header="Colonne / alias" Binding="{Binding Column, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1.8*" MinWidth="250" />
                                            <DataGridTemplateColumn Header="Sens" Width="160" MinWidth="150">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ComboBox ItemsSource="{Binding DataContext.SortDirections, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding Direction, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Action" Width="190" MinWidth="170">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="Retirer" HorizontalAlignment="Stretch" MinWidth="145" Padding="12,4" Command="{Binding DataContext.RemoveOrderByCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </TabItem>

                            <TabItem Header="Colonnes calculées">
                                <DockPanel AllowDrop="True" Drop="CustomCase_Drop" DragOver="Drop_DragOver" LastChildFill="True">
                                    <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                                        <TextBlock Text="CASE WHEN ou expression SELECT contrôlée. Dépose une colonne pour créer un CASE." VerticalAlignment="Center" Margin="8,4" FontWeight="Normal" />
                                        <Button Content="Ajouter colonne personnalisée" Command="{Binding AddEmptyCustomColumnCommand}" />
                                    </WrapPanel>
                                    <DataGrid ItemsSource="{Binding CustomColumns}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Alias" Binding="{Binding Alias, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1.2*" MinWidth="160" />
                                            <DataGridTextColumn Header="Expression brute" Binding="{Binding RawExpression, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="2.2*" MinWidth="300" />
                                            <DataGridTextColumn Header="Table CASE" Binding="{Binding CaseTable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1.4*" MinWidth="180" />
                                            <DataGridTextColumn Header="Colonne CASE" Binding="{Binding CaseColumn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1.4*" MinWidth="180" />
                                            <DataGridTemplateColumn Header="Opérateur" Width="150" MinWidth="145">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ComboBox ItemsSource="{Binding DataContext.Operators, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding CaseOperator, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Si valeur" Binding="{Binding CaseCompareValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1*" MinWidth="140" />
                                            <DataGridTextColumn Header="Alors" Binding="{Binding CaseThenValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1*" MinWidth="140" />
                                            <DataGridTextColumn Header="Sinon" Binding="{Binding CaseElseValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1*" MinWidth="140" />
                                            <DataGridTemplateColumn Header="Action" Width="330" MinWidth="310">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                                                            <Button Content="+ Filtre" MinWidth="80" Padding="8,4" Command="{Binding DataContext.AddCustomFilterCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" ToolTip="Ajoute cette colonne calculée comme filtre." />
                                                            <Button Content="+ Tri" MinWidth="70" Padding="8,4" Command="{Binding DataContext.AddCustomOrderByCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" ToolTip="Ajoute cette colonne calculée au ORDER BY." />
                                                            <Button Content="Retirer" MinWidth="100" Padding="8,4" Command="{Binding DataContext.RemoveCustomColumnCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </TabItem>

                            <TabItem Header="Sous-requêtes / sauvegarde">
                                <Grid Margin="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Background="#FFFFFF" Padding="8" Margin="4">
                                        <DockPanel LastChildFill="True">
                                            <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                                                <TextBlock Text="Nom" FontWeight="SemiBold" VerticalAlignment="Center" Margin="4" />
                                                <TextBox Width="230" Text="{Binding QueryName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Text="Description" FontWeight="SemiBold" VerticalAlignment="Center" Margin="14,4,4,4" />
                                                <TextBox Width="420" Text="{Binding QueryDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <Button Content="Sauvegarder requête" Command="{Binding SaveCurrentQueryCommand}" />
                                                <Button Content="Recharger bibliothèque" Command="{Binding ReloadSavedQueriesCommand}" />
                                                <Button Content="Charger sélection" Command="{Binding LoadSelectedQueryCommand}" />
                                                <Button Content="Utiliser comme sous-requête filtrante" Command="{Binding AddSelectedSavedQueryAsSubqueryFilterCommand}" ToolTip="Ajoute la requête sauvegardée sélectionnée comme filtre IN/=/EXISTS. Si une colonne est sélectionnée dans l'arbre de gauche, elle devient la colonne filtrée." />
                                            </WrapPanel>
                                            <TextBlock Text="Sauvegarde locale JSON dans le dossier saved_queries. Les paramètres sont conservés comme :nom_param ou ?. Une sous-requête sauvegardée peut être réutilisée dans les filtres de la requête principale." TextWrapping="Wrap" Foreground="#475569" />
                                        </DockPanel>
                                    </Border>

                                    <GroupBox Grid.Row="1" Header="Paramètres de la requête / sous-requête" Margin="4">
                                        <DockPanel LastChildFill="True">
                                            <Button DockPanel.Dock="Top" HorizontalAlignment="Left" Content="+ Paramètre" Command="{Binding AddParameterCommand}" />
                                            <DataGrid ItemsSource="{Binding Parameters}" MinHeight="110">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Nom" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1*" MinWidth="150" />
                                                    <DataGridTextColumn Header="Description" Binding="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="2*" MinWidth="260" />
                                                    <DataGridTextColumn Header="Valeur par défaut" Binding="{Binding DefaultValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1.2*" MinWidth="180" />
                                                    <DataGridCheckBoxColumn Header="Obligatoire" Binding="{Binding Required, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                                                    <DataGridTemplateColumn Header="Action" Width="160" MinWidth="150">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Button Content="Retirer" MinWidth="120" Command="{Binding DataContext.RemoveParameterCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </DockPanel>
                                    </GroupBox>

                                    <GroupBox Grid.Row="2" Header="Bibliothèque de requêtes sauvegardées" Margin="4">
                                        <DataGrid ItemsSource="{Binding SavedQueries}" SelectedItem="{Binding SelectedSavedQuery, Mode=TwoWay}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Nom" Binding="{Binding Name}" Width="1.4*" MinWidth="180" />
                                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2.5*" MinWidth="300" />
                                                <DataGridTextColumn Header="Base" Binding="{Binding BaseTable}" Width="1*" MinWidth="140" />
                                                <DataGridTextColumn Header="Params" Binding="{Binding Parameters}" Width="1.6*" MinWidth="220" />
                                                <DataGridTextColumn Header="Nb champs" Binding="{Binding SelectCount}" Width="100" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </GroupBox>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </GroupBox>
            </Grid>

            <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" Background="#CBD5E1" />

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" MinWidth="900" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" MinWidth="360" />
                </Grid.ColumnDefinitions>

                <GroupBox Grid.Column="0" Header="3. SQL généré">
                    <DockPanel LastChildFill="True">
                        <TextBlock DockPanel.Dock="Top" Text="Copie-colle dans SQLite Browser, Oracle SQL Developer, DBeaver, etc. L'outil ne lance jamais de DELETE/UPDATE." Style="{StaticResource SectionHint}" />
                        <TextBox Text="{Binding GeneratedSql, Mode=OneWay}"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap" />
                    </DockPanel>
                </GroupBox>

                <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="#CBD5E1" />

                <GroupBox Grid.Column="2" Header="But / validation">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#EFF6FF" BorderBrush="#93C5FD" BorderThickness="1" CornerRadius="6" Padding="8" Margin="4">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Top" Text="But probable de la requête" FontWeight="Bold" Foreground="#1E3A8A" Margin="0,0,0,4" />
                                <TextBlock Text="{Binding QueryPurpose, Mode=OneWay}" TextWrapping="Wrap" Foreground="#1F2937" />
                            </DockPanel>
                        </Border>
                        <Border Grid.Row="2" Background="#F0FDF4" BorderBrush="#86EFAC" BorderThickness="1" CornerRadius="6" Padding="8" Margin="4">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Top" Text="Analyse performance heuristique" FontWeight="Bold" Foreground="#166534" Margin="0,0,0,4" />
                                <TextBlock Text="{Binding PerformanceReport, Mode=OneWay}" TextWrapping="Wrap" Foreground="#1F2937" />
                            </DockPanel>
                        </Border>
                        <TextBox Grid.Row="4" Text="{Binding Warnings, Mode=OneWay}"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap" />
                    </Grid>
                </GroupBox>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
