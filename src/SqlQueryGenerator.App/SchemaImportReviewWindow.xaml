<Window x:Class="SqlQueryGenerator.App.SchemaImportReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Revue des tables backup"
        Height="520"
        Width="980"
        MinHeight="420"
        MinWidth="860"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Des tables ressemblant à des copies backup/archive/save ont été détectées dans le DDL. Vérifie la sélection avant l'import final."
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"
                   Foreground="#334155" />

        <DockPanel Grid.Row="1" Margin="0,0,0,10" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left"
                       Text="{Binding SelectionSummary}"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Foreground="#0F172A" />
            <WrapPanel DockPanel.Dock="Right">
                <Button Content="Tout exclure"
                        Click="SelectAll_Click"
                        Margin="0,0,8,0" />
                <Button Content="Tout garder"
                        Click="ClearAll_Click" />
            </WrapPanel>
        </DockPanel>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Candidates}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  IsReadOnly="False"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Exclure"
                                        Binding="{Binding IsExcluded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="84" />
                <DataGridTextColumn Header="Table détectée"
                                    Binding="{Binding TableName}"
                                    Width="2*" />
                <DataGridTextColumn Header="Table de base"
                                    Binding="{Binding BaseTableName}"
                                    Width="2*" />
                <DataGridTextColumn Header="Raison"
                                    Binding="{Binding DetectionReason}"
                                    Width="3*" />
            </DataGrid.Columns>
        </DataGrid>

        <DockPanel Grid.Row="3" Margin="0,12,0,0" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left"
                       Text="Les lignes cochées seront exclues du schéma final. Les tables non cochées resteront importées."
                       VerticalAlignment="Center"
                       Foreground="#475569" />
            <WrapPanel DockPanel.Dock="Right">
                <Button Content="Importer sans les tables sélectionnées"
                        Click="ImportSelected_Click"
                        Margin="0,0,8,0" />
                <Button Content="Conserver toutes les tables"
                        Click="KeepAll_Click"
                        Margin="0,0,8,0" />
                <Button Content="Annuler"
                        IsCancel="True"
                        Click="Cancel_Click" />
            </WrapPanel>
        </DockPanel>
    </Grid>
</Window>
